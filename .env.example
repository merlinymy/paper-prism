# ============================================================
# PaperPrism Configuration
# ============================================================
# Copy this file:  cp .env.example .env
# Then fill in your API keys below.
# ============================================================

# --- API Keys (required) ---
# Get these from:
#   Anthropic: https://console.anthropic.com/
#   Voyage AI: https://dash.voyageai.com/
#   Cohere:    https://dashboard.cohere.com/
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# --- Auth ---
# Auth is OFF by default (no login needed for local use).
# Turn it on if you expose PaperPrism to the internet.
ENABLE_AUTH=false
# JWT_SECRET=change-me-to-a-random-64-character-string
# DEFAULT_USERNAME=admin
# DEFAULT_PASSWORD=changeme

# --- LLM Models (defaults work, change if you want different models) ---
# CLAUDE_MODEL=claude-opus-4-5-20251101
# CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
# CLAUDE_MODEL_CLASSIFIER=claude-sonnet-4-5-20250929

# --- Advanced (usually don't need to change) ---
# QDRANT_COLLECTION_NAME=research_papers
# EMBEDDING_MODEL=voyage-3-large
# EMBEDDING_DIMENSION=1024
# MAX_UPLOAD_SIZE_MB=200
# PDF_EXTRACTION_TIMEOUT=900
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
